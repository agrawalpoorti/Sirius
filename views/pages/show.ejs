<% layout("layouts/boilerplate") %>

<div class="page-wrapper">
    <div class="listing-container">
        <div class="section-header">
            <div>
                <p class="section-kicker">Task Dashboard</p>
                <h2><%= pageTitle || "Listing Details" %></h2>
            </div>
            <a href="/listings/new" class="action-btn">Add Task</a>
        </div>

        <% if (!listings.length) { %>
            <div class="empty-state">
                <h3><%= emptyTitle || "No tasks found" %></h3>
                <p><%= emptyCopy || "Try creating a new task to get started." %></p>
            </div>
        <% } %>

        <% for(let listing of listings){ %>
            <% const displayStatus = getListingDisplayStatus(listing); %>
            <% const isOverdue = isListingOverdue(listing); %>

            <div class="listing-card">
                <div class="listing-header">
                    <h3><%= listing.title %></h3>

                    <span class="status-badge <%= displayStatus.toLowerCase() %>">
                        <%= displayStatus %>
                    </span>
                </div>

                <div class="listing-field">
                    <label>Description</label>
                    <p><%= listing.description || "No description provided" %></p>
                </div>

                <div class="listing-grid">
                    <div class="listing-field">
                        <label>Category</label>
                        <p><%= listing.category %></p>
                    </div>

                    <div class="listing-field">
                        <label>Deadline</label>
                        <p><%= listing.deadline ? new Date(listing.deadline).toDateString() : "No deadline" %></p>
                    </div>

                    <div class="listing-field">
                        <label>Estimated Time</label>
                        <p><%= listing.estimatedMinutes %> minutes</p>
                    </div>
                </div>

                <div class="listing-actions">
                    <a href="/listings/<%= listing._id %>" class="action-btn show-btn">Show</a>
                    <% if (isOverdue) { %>
                        <span class="action-btn disabled-btn">Edit Disabled</span>
                    <% } else { %>
                        <a href="/listings/<%= listing._id %>/edit" class="action-btn edit-btn">Edit</a>
                    <% } %>

                    <form action="/listings/<%= listing._id %>/status?_method=PATCH" method="POST">
                        <input type="hidden" name="status" value="<%= listing.status === 'Completed' ? 'Pending' : 'Completed' %>">
                        <button class="action-btn complete-btn">
                            <%= listing.status === 'Completed' ? 'Mark Pending' : 'Mark Complete' %>
                        </button>
                    </form>

                    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                        <button class="action-btn delete-btn">Delete</button>
                    </form>
                </div>
            </div>
        <% } %>
    </div>
</div>
